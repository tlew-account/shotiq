  document.getElementById('sm-name').value = stat?.name||'';
  document.getElementById('sm-value').value = stat?.value!==undefined ? stat.value : 1;
  openModal('modal-stat');
}
function saveStat() {
  const name = document.getElementById('sm-name').value.trim();
  const value = parseFloat(document.getElementById('sm-value').value)||0;
  if (!name) return showToast('Stat name is required');
  const { catId, stat } = editingStat;
