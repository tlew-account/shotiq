// Evaluate a formula given a statValues map (aggregated across entries)
function evaluateFormula(formula, statValues) {
  try {
    // Build JS expression string from tokens
    const expr = formula.tokens.map(t => {
      if (t.type === 'stat')  return parseFloat(statValues[t.id] || 0).toString();
      if (t.type === 'num')   return t.value;
      if (t.type === 'op') {
        if (t.value === '/')  return '/';
        if (t.value === '*')  return '*';
        if (t.value === '+')  return '+';
        if (t.value === '-')  return '-';
        return t.value; // ( )
      }
      return '0';
    }).join(' ');

    if (!expr.trim()) return null;
    // Safe eval: only allow numbers, operators, parens, whitespace
    if (!/^[\d\s\.\+\-\*\/\(\)]+$/.test(expr)) return null;
    // eslint-disable-next-line no-new-func
    const result = Function('"use strict"; return (' + expr + ')')();
    if (!isFinite(result)) return null;
    return result;
  } catch(e) { return null; }
}

// Aggregate statValues across a list of entries
function aggregateStatValues(entryList) {
  const agg = {};
  entryList.forEach(e => {
    Object.entries(e.statValues || {}).forEach(([k, v]) => {
      agg[k] = (agg[k] || 0) + parseFloat(v || 0);
    });
  });
  return agg;
}

// Format a formula result for display
function formatFormulaResult(val, format) {
  if (val === null || val === undefined) return '—';
  if (format === 'percent')  return (val * 100).toFixed(1) + '%';
  if (format === 'decimal2') return val.toFixed(2);
  if (format === 'decimal1') return val.toFixed(1);
  if (format === 'integer')  return Math.round(val).toString();
  return val.toFixed(2);
}

// Render a formula result badge
function formulaResultBadge(formula, entryList) {
  const agg = aggregateStatValues(entryList);
  const result = evaluateFormula(formula, agg);
  const display = formatFormulaResult(result, formula.format);
  return `<div class="formula-result-badge" style="background:${formula.color}18;">
    <span class="frb-val" style="color:${formula.color};">${display}</span>
    <span class="frb-lbl" style="color:${formula.color}cc;">${formula.name}</span>
  </div>`;
}

// Human-readable expression string with stat names
function formulaExprDisplay(formula) {
  return formula.tokens.map(t => {
    if (t.type === 'stat') {
      // Find the stat color
      let color = '#555';
      categories.forEach(c => { if (c.stats.find(s=>s.id===t.id)) color = c.color; });
      return `<span class="expr-stat-chip" style="background:${color}18;color:${color};">${t.label}</span>`;
    }
    if (t.type === 'num') return `<span style="color:#1a5cb5;font-weight:700;">${t.label}</span>`;
    const sym = t.label === '÷' ? '÷' : t.label === '×' ? '×' : t.label === '−' ? '−' : t.label;
    return `<span style="color:var(--text2);padding:0 2px;">${sym}</span>`;
  }).join('');
}

// ── Formulas Page ──
function renderFormulas() {
  const el = document.getElementById('formulas-list');
  if (!formulas.length) {
    el.innerHTML = '<div class="empty"><i class="fa-solid fa-square-root-variable"></i><p>No formulas yet. Add one above.</p></div>';
    return;
  }
  el.innerHTML = formulas.map(f => `
    <div class="formula-card">
      <div class="formula-card-icon" style="background:${f.color}18;color:${f.color};">ƒ</div>
      <div class="formula-card-body">
        <div class="formula-card-name">${f.name}</div>
        ${f.desc ? `<div class="formula-card-desc">${f.desc}</div>` : ''}
        <div class="formula-card-expr">${formulaExprDisplay(f)}</div>
        <div style="margin-top:6px;font-size:11px;color:var(--text3);">Format: ${fmtLabel(f.format)}</div>
      </div>
      <div class="formula-card-actions">
        <button class="btn-icon" onclick="openFormulaModal('${f.id}')"><i class="fa-solid fa-pen"></i></button>
        <button class="btn-icon danger" onclick="deleteFormula('${f.id}')"><i class="fa-solid fa-trash"></i></button>
      </div>
    </div>`).join('');
}

function fmtLabel(f) {
  return {percent:'% Percentage', decimal2:'0.00 Decimal', decimal1:'0.0 Decimal', integer:'# Integer'}[f] || f;
}

function deleteFormula(id) {
  if (!confirm('Delete this formula?')) return;
  formulas = formulas.filter(f=>f.id!==id);
  markDirty();
  renderFormulas();
  showToast('Formula deleted');
}

// ── Formula Modal state ──
let fmTokens = [];    // working token list
let fmFormat = 'percent';

function openFormulaModal(fid) {
  editingFormula = fid ? formulas.find(f=>f.id===fid) : null;
  document.getElementById('formula-modal-title').textContent = fid ? 'Edit Formula' : 'Add Formula';
  document.getElementById('fm-name').value = editingFormula?.name || '';
  document.getElementById('fm-desc').value = editingFormula?.desc || '';

  fmTokens = editingFormula ? JSON.parse(JSON.stringify(editingFormula.tokens)) : [];
  fmFormat = editingFormula?.format || 'percent';
  selectedFormulaColor = editingFormula?.color || COLORS[0];

  // Format buttons
  document.querySelectorAll('.fmt-btn').forEach(b => b.classList.toggle('active', b.dataset.fmt === fmFormat));

  // Color picker
  buildColorPicker('fm-colors', selectedFormulaColor);

  // Stat tokens for insertion
  renderStatInsertButtons();
  renderExprTokens();
  const exprInp = document.getElementById('fm-expr-input');
  if (exprInp) exprInp.value = '';
  const numInp = document.getElementById('fm-num-input');
  if (numInp) numInp.value = '';

  openModal('modal-formula');
}

function renderStatInsertButtons() {
  const container = document.getElementById('fm-stat-tokens');
  container.innerHTML = categories.map(cat =>
    cat.stats.map(s => `
      <button class="stat-insert-btn"
        style="color:${cat.color};border-color:${cat.color}33;background:${cat.color}0d;"
        onclick="insertStat('${s.id}','${s.name.replace(/'/g,"\\'")}','${cat.color}')">
        ${s.name}
      </button>`).join('')
  ).join('');
}

function renderExprTokens() {
  const container = document.getElementById('fm-expr-tokens');
  container.innerHTML = fmTokens.map((t, i) => {
    let bg = 'var(--gray1)', color = 'var(--navy)';
    if (t.type === 'stat') {
      let c = '#555';
      categories.forEach(cat => { if (cat.stats.find(s=>s.id===t.id)) c = cat.color; });
      bg = c + '18'; color = c;
    }
    if (t.type === 'num') { bg = '#e8f0fe'; color = '#1a5cb5'; }
    return `<span class="expr-token" style="background:${bg};color:${color};">
      ${t.label}
      <span class="expr-token-del" onclick="removeToken(${i})">✕</span>
    </span>`;
  }).join('');
  updateExprPreview();
}

function insertStat(id, name, color) {
  fmTokens.push({type:'stat', id, label:name});
  renderExprTokens();
  document.getElementById('fm-expr-input').focus();
}

const OP_MAP = {'+':'+', '−':'-', '×':'*', '÷':'/', '(':'(', ')':')'};
function insertOperator(sym) {
  fmTokens.push({type:'op', label:sym, value: OP_MAP[sym] || sym});
  renderExprTokens();
  document.getElementById('fm-expr-input').focus();
}

function removeToken(i) {
  fmTokens.splice(i, 1);
  renderExprTokens();
}

function clearExpr() {
  fmTokens = [];
  renderExprTokens();
}

function focusExprInput() {
  // Focus the number input for convenience
  const num = document.getElementById('fm-num-input');
  if (num) num.focus();
}

// Commit whatever is in the number input as a num token
function commitNumber() {
  const inp = document.getElementById('fm-num-input');
  if (!inp) return;
  const val = inp.value.trim();
  if (val === '' || isNaN(parseFloat(val))) {
    inp.style.borderColor = '#c62828';
    setTimeout(() => { inp.style.borderColor = 'var(--gray2)'; }, 800);
    return;
  }
  const num = parseFloat(val);
  // Format cleanly: remove trailing zeros but keep decimals if needed
  const label = String(num);
  fmTokens.push({ type: 'num', label, value: label });
  inp.value = '';
  inp.focus();
  renderExprTokens();
}

function onExprInput() {
  updateExprPreview();
}

function onExprKeydown(e) {
  // Backspace on empty hidden input removes last token
  if (e.key === 'Backspace' && fmTokens.length) {
    fmTokens.pop();
    renderExprTokens();
  }
}

function selectFmtBtn(btn) {
  fmFormat = btn.dataset.fmt;
  document.querySelectorAll('.fmt-btn').forEach(b => b.classList.toggle('active', b === btn));
  updateExprPreview();
}

function updateExprPreview() {
  const preview = document.getElementById('fm-expr-preview');
  if (!preview) return;
  // Include any number currently typed in the number input (for live preview)
  const numInp = document.getElementById('fm-num-input');
  const typed = numInp ? numInp.value.trim() : '';
  const tempTokens = [...fmTokens, ...(typed && !isNaN(parseFloat(typed)) ? [{type:'num',label:typed,value:typed}] : [])];

  // Nothing entered yet — hide preview silently
  if (!tempTokens.length) { preview.style.display = 'none'; return; }

  const testVals = {};
  categories.forEach(c => c.stats.forEach(s => { testVals[s.id] = 1; }));
  const result = evaluateFormula({tokens: tempTokens}, testVals);

  if (result !== null) {
    preview.style.display = '';
    preview.textContent = '✓ Valid — sample result (all stats = 1): ' + formatFormulaResult(result, fmFormat);
    preview.style.background = '#e8f5e9';
    preview.style.color = '#2e7d32';
  } else {
    // Only show invalid warning if there are already committed tokens (not just while typing)
    if (fmTokens.length) {
      preview.style.display = '';
      preview.textContent = '⚠ Expression incomplete or invalid — keep adding tokens';
      preview.style.background = '#fff3e0';
      preview.style.color = '#e65100';
    } else {
      preview.style.display = 'none';
    }
  }
}

function saveFormula() {
  const name = document.getElementById('fm-name').value.trim();
  if (!name) return showToast('Formula name is required');

  // Flush any pending number in the number input
  const numInp = document.getElementById('fm-num-input');
  const typed = numInp ? numInp.value.trim() : '';
  if (typed !== '' && !isNaN(parseFloat(typed))) {
    fmTokens.push({ type: 'num', label: typed, value: typed });
    if (numInp) numInp.value = '';
  }
  if (!fmTokens.length) return showToast('Please build an expression');

  const testVals = {};
  categories.forEach(c => c.stats.forEach(s => { testVals[s.id] = 1; }));
  const test = evaluateFormula({tokens:fmTokens}, testVals);
  if (test === null) return showToast('Expression is invalid or incomplete');

  const data = {
    name,
    desc: document.getElementById('fm-desc').value.trim(),
    format: fmFormat,
    color: selectedFormulaColor,
    tokens: JSON.parse(JSON.stringify(fmTokens)),
  };

  if (editingFormula) {
    formulas = formulas.map(f => f.id === editingFormula.id ? {...f, ...data} : f);
  } else {
    formulas.push({id: genId(), ...data});
  }

  closeModal('modal-formula');
  markDirty();
  renderFormulas();
  showToast(editingFormula ? 'Formula updated' : 'Formula added');
}

// Override buildColorPicker to also handle formula colors
function buildColorPicker(containerId, selectedColor) {
  const el = document.getElementById(containerId);
  if (!el) return;
  el.innerHTML = COLORS.map(c => `
    <div class="color-swatch ${c===selectedColor?'selected':''}" style="background:${c};"
      onclick="selectColor('${containerId}','${c}')"></div>
  `).join('');
}
// ═══════════════════════════════════════════════════════
function exportCSV(entryList, title) {
  const allStats = categories.flatMap(c => c.stats.map(s=>({...s, catName:c.name})));
  const header = ['Date','Player','Team','Opponent','Score',...allStats.map(s=>s.name),...formulas.map(f=>f.name)];
  const rows = entryList.map(e => {
    const p = players.find(x=>x.id===e.playerId);
    const t = teams.find(x=>x.id===e.teamId);
    const fVals = formulas.map(f => {
      const r = evaluateFormula(f, e.statValues);
      return r !== null ? formatFormulaResult(r, f.format) : '—';
    });
    return [e.date, p?.name||'', t?.name||'', e.opponent||'', computeScore(e.statValues),
            ...allStats.map(s=>e.statValues[s.id]||0), ...fVals];
  });
  const csv = [header,...rows].map(r=>r.map(v=>`"${v}"`).join(',')).join('\n');
  const blob = new Blob([csv],{type:'text/csv'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href=url; a.download=title.replace(/\s/g,'_')+'_stats.csv'; a.click();
  showToast('CSV downloaded');
}

function exportPDF(entryList, title) {
  const allStats = categories.flatMap(c => c.stats.map(s=>({...s})));
  const rows = entryList.map(e => {
    const p = players.find(x=>x.id===e.playerId);
    const t = teams.find(x=>x.id===e.teamId);
    const fVals = formulas.map(f => {
      const r = evaluateFormula(f, e.statValues);
      return `<td>${r !== null ? formatFormulaResult(r, f.format) : '—'}</td>`;
    }).join('');
    return `<tr>
      <td>${e.date}</td><td>${p?.name||'—'}</td><td>${t?.name||'—'}</td>
      <td>${e.opponent||'—'}</td><td><strong>${computeScore(e.statValues)}</strong></td>
      ${allStats.map(s=>`<td>${e.statValues[s.id]||0}</td>`).join('')}
      ${fVals}
    </tr>`;
  }).join('');
  const html = `<!DOCTYPE html><html><head><title>${title} – Stats Report</title>
  <style>body{font-family:Arial,sans-serif;padding:24px;color:#1a2d42}
  h1{font-size:22px;margin-bottom:4px}p{font-size:13px;color:#666;margin-bottom:18px}
  table{width:100%;border-collapse:collapse;font-size:11px}
  th{background:#0d1b2a;color:#fff;padding:7px 10px;text-align:left}
  td{padding:6px 10px;border-bottom:1px solid #e0e0e0}
  tr:nth-child(even) td{background:#f7f9fb}
  .fml{background:#e8f5e9;color:#2e7d32;}</style></head>
  <body><h1>📊 ${title} – Statistics Report</h1>
  <p>Generated on ${new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})} · ${entryList.length} entries</p>
  <table><thead><tr><th>Date</th><th>Player</th><th>Team</th><th>Opponent</th><th>Score</th>${allStats.map(s=>`<th>${s.name}</th>`).join('')}${formulas.map(f=>`<th class="fml">${f.name}</th>`).join('')}</tr></thead>
  <tbody>${rows}</tbody></table></body></html>`;
  const w = window.open('','_blank');
  w.document.write(html);
  w.document.close();
  setTimeout(()=>w.print(), 600);
}

