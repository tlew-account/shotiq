    </div>

    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-formula')">Cancel</button>
      <button class="btn btn-primary" onclick="saveFormula()">Save Formula</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast"></div>

<script>
// ═══════════════════════════════════════════════════════
//  DEFAULTS
// ═══════════════════════════════════════════════════════
const COLORS = ['#0d47a1','#1565c0','#1e88e5','#43a047','#2e7d32','#f57c00','#e64a19','#c62828','#6a1b9a','#00838f','#37474f','#795548'];

const DEFAULT_CATEGORIES = [
  { id:'off', name:'Offense', color:'#c62828', stats:[
