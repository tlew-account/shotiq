            onfocus="this.style.borderColor='var(--navy)'" onblur="this.style.borderColor='var(--gray2)'"
            oninput="updateExprPreview()"
            onkeydown="if(event.key==='Enter'){event.preventDefault();commitNumber();}">
          <button class="op-btn" onclick="commitNumber()" style="padding:5px 14px;font-size:13px;font-family:'Mulish',sans-serif;">Add →</button>
        </div>
        <div style="margin-top:10px;">
          <span style="font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">Operators</span>
          <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;" id="fm-op-btns">
