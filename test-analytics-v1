  ]}
];
const DEFAULT_PLAYERS = [
  {id:'p1',name:'Marcus Johnson',number:'23',position:'SG',teamId:'t1',color:'#1565c0'},
  {id:'p2',name:'Devon Williams',number:'11',position:'PG',teamId:'t1',color:'#2e7d32'},
