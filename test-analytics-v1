        <div style="margin-top:10px;">
          <span style="font-size:11px;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:0.4px;display:block;margin-bottom:6px;">Insert Stat</span>
          <div id="fm-stat-tokens" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
