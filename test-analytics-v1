// tokens: array of {type:'stat'|'op'|'num', id?, label, value?}
const DEFAULT_FORMULAS = [
  {
    id:'fgpct', name:'Field Goal %', desc:'(2PT Made + 3PT Made) ÷ (2PT Att + 3PT Att)',
    format:'percent', color:'#1565c0',
    tokens:[
      {type:'op',label:'(',value:'('},
      {type:'stat',id:'fg2m',label:'2PT Made'},
      {type:'op',label:'+',value:'+'},
      {type:'stat',id:'fg3m',label:'3PT Made'},
      {type:'op',label:')',value:')'},
      {type:'op',label:'÷',value:'/'},
      {type:'op',label:'(',value:'('},
      {type:'stat',id:'fg2a',label:'2PT Att'},
      {type:'op',label:'+',value:'+'},
      {type:'stat',id:'fg3a',label:'3PT Att'},
      {type:'op',label:')',value:')'},
    ]
  },
  {
    id:'efgpct', name:'Eff. FG %', desc:'(2PT Made + 1.5 × 3PT Made) ÷ (2PT Att + 3PT Att)',
    format:'percent', color:'#2e7d32',
    tokens:[
      {type:'op',label:'(',value:'('},
      {type:'stat',id:'fg2m',label:'2PT Made'},
      {type:'op',label:'+',value:'+'},
