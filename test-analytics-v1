<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CourtIQ – Basketball Statistics</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Mulish:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
  :root {
    --navy: #0d1b2a;
    --navy2: #1a2d42;
    --navy3: #243447;
    --red: #e83a3a;
    --red2: #c42d2d;
    --gold: #f5a623;
    --gold2: #d4891a;
    --white: #ffffff;
    --offwhite: #f4f6f8;
    --gray1: #e8ecf0;
    --gray2: #c8d0db;
    --gray3: #8a96a6;
    --gray4: #4a5568;
    --text: #1a2d42;
    --text2: #4a5568;
    --text3: #8a96a6;
    --cat-off: #e8392a;
    --cat-trans: #1d6fa4;
    --cat-def: #2d9e5a;
    --cat-ov: #d4891a;
    --shadow: 0 4px 24px rgba(13,27,42,0.13);
    --shadow2: 0 2px 10px rgba(13,27,42,0.09);
    --radius: 12px;
    --radius2: 8px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Mulish', sans-serif;
    background: var(--offwhite);
    color: var(--text);
    min-height: 100vh;
  }

  /* ─── HEADER ─── */
  #header {
    background: var(--navy);
    display: flex;
    align-items: center;
    padding: 0 28px;
    position: sticky;
    top: 0;
    z-index: 200;
    box-shadow: 0 2px 16px rgba(0,0,0,0.3);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 0;
    margin-right: 32px;
    flex-shrink: 0;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: var(--red);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; color: #fff;
  }
  .logo-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 800;
    font-size: 22px;
    color: #fff;
    letter-spacing: 1px;
  }
  .logo-text span { color: var(--red); }

  /* ─── SAVE STATUS ─── */
  #save-status {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
    padding-left: 16px;
  }
  #save-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    transition: color 0.3s;
    white-space: nowrap;
  }
  #save-indicator .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    transition: background 0.3s;
    flex-shrink: 0;
  }
  #save-indicator.unsaved { color: var(--gold); }
  #save-indicator.unsaved .dot { background: var(--gold); animation: pulse-dot 1.2s ease-in-out infinite; }
  #save-indicator.saved { color: #4caf82; }
  #save-indicator.saved .dot { background: #4caf82; }
  #save-indicator.saving { color: rgba(255,255,255,0.55); }
  #save-indicator.saving .dot { background: rgba(255,255,255,0.4); animation: pulse-dot 0.6s ease-in-out infinite; }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.75); }
  }
  #btn-save-now {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.85);
    padding: 6px 14px;
    border-radius: 7px;
    font-family: 'Mulish', sans-serif;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    display: flex; align-items: center; gap: 6px;
    transition: background 0.14s, border-color 0.14s, color 0.14s;
    white-space: nowrap;
  }
  #btn-save-now:hover { background: rgba(255,255,255,0.18); border-color: rgba(255,255,255,0.35); color: #fff; }
  #btn-save-now:active { background: rgba(255,255,255,0.08); }

  nav { display: flex; gap: 2px; overflow-x: auto; }
  nav button {
    background: none;
    border: none;
    color: rgba(255,255,255,0.55);
    padding: 16px 16px;
    cursor: pointer;
    font-family: 'Mulish', sans-serif;
    font-size: 13px;
    font-weight: 600;
    display: flex; align-items: center; gap: 7px;
    border-bottom: 2.5px solid transparent;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }
  nav button:hover { color: rgba(255,255,255,0.85); }
  nav button.active {
    color: #fff;
    border-bottom-color: var(--red);
    background: rgba(255,255,255,0.07);
  }
  nav button i { font-size: 15px; }

  /* ─── LAYOUT ─── */
  #app { max-width: 960px; margin: 0 auto; padding: 28px 20px 60px; }

  .page { display: none; }
  .page.active { display: block; }

  .page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--navy);
    letter-spacing: 0.5px;
    margin-bottom: 22px;
  }

  /* ─── CARDS ─── */
  .card {
    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow2);
    border: 1px solid var(--gray1);
  }
  .card-body { padding: 20px 24px; }

  /* ─── BUTTONS ─── */
  .btn {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 8px 16px;
    border-radius: var(--radius2);
    font-family: 'Mulish', sans-serif;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid var(--gray2);
    background: #fff;
    color: var(--text);
    transition: all 0.14s;
  }
  .btn:hover { background: var(--gray1); }
  .btn-primary {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }
  .btn-primary:hover { background: var(--navy2); }
  .btn-red {
    background: var(--red);
    color: #fff;
    border-color: var(--red);
  }
  .btn-red:hover { background: var(--red2); }
  .btn-gold {
    background: var(--gold);
    color: #fff;
    border-color: var(--gold);
  }
  .btn-gold:hover { background: var(--gold2); }
  .btn-sm { padding: 5px 11px; font-size: 12px; }
  .btn-icon {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--gray3);
    font-size: 14px;
    padding: 5px 7px;
    border-radius: 6px;
    transition: color 0.13s, background 0.13s;
    display: inline-flex; align-items: center;
  }
  .btn-icon:hover { background: var(--gray1); color: var(--text); }
  .btn-icon.danger:hover { color: var(--red); background: #fde8e8; }

  /* ─── FORMS ─── */
  .form-group { margin-bottom: 14px; }
  .form-group label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    color: var(--text2);
    margin-bottom: 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .form-control {
    width: 100%;
    padding: 9px 13px;
    border: 1.5px solid var(--gray2);
    border-radius: var(--radius2);
    font-family: 'Mulish', sans-serif;
    font-size: 14px;
    color: var(--text);
    background: #fff;
    transition: border-color 0.14s;
    outline: none;
  }
  .form-control:focus { border-color: var(--navy); }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .form-row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; }

  /* ─── STAT BADGE ─── */
  .stat-badge {
    display: inline-flex; flex-direction: column; align-items: center;
    padding: 6px 12px;
    border-radius: 8px;
    min-width: 60px;
  }
  .stat-badge .val {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
  }
  .stat-badge .lbl {
    font-size: 10px;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
    margin-top: 2px;
  }

  /* ─── AVATAR ─── */
  .avatar {
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  /* ─── METRIC CARDS ─── */
  .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; margin-bottom: 22px; }
  .metric-card {
    background: #fff;
    border-radius: var(--radius);
    box-shadow: var(--shadow2);
    border: 1px solid var(--gray1);
    padding: 16px 20px;
    border-top: 3px solid var(--gray2);
  }
  .metric-card .mc-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    display: flex; align-items: center; gap: 6px;
    margin-bottom: 6px;
  }
  .metric-card .mc-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 34px;
    font-weight: 800;
    color: var(--navy);
    line-height: 1;
  }

  /* ─── CATEGORY BLOCKS ─── */
  .cat-block {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray1);
    border-left: 4px solid;
    box-shadow: var(--shadow2);
    margin-bottom: 14px;
    overflow: hidden;
  }
  .cat-block-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border-bottom: 1px solid var(--gray1);
  }
  .cat-block-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .cat-block-stats { padding: 14px 18px; }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 10px; }

  /* Log form stat inputs */
  .stat-input-item {
    background: var(--offwhite);
    border-radius: 8px;
    padding: 10px 12px;
  }
  .stat-input-item label {
    font-size: 11px;
    font-weight: 700;
    color: var(--text2);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    display: flex;
    justify-content: space-between;
    margin-bottom: 5px;
  }
  .stat-input-item label span { font-weight: 400; color: var(--text3); }
  .stat-input-item input {
    width: 100%;
    padding: 7px 10px;
    border: 1.5px solid var(--gray2);
    border-radius: 6px;
    font-size: 15px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    color: var(--text);
    background: #fff;
    outline: none;
    transition: border-color 0.13s;
  }
  .stat-input-item input:focus { border-color: var(--navy); }

  /* Categories manage stat item */
  .stat-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--offwhite);
    border-radius: 8px;
    padding: 8px 12px;
    gap: 8px;
  }
  .stat-pill-info { flex: 1; min-width: 0; }
  .stat-pill-name {
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .stat-pill-val { font-size: 11px; color: var(--text3); }
  .stat-pill-actions { display: flex; gap: 3px; flex-shrink: 0; }

  /* Player / team cards */
  .profile-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 14px; }
  .profile-card {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray1);
    box-shadow: var(--shadow2);
    padding: 18px;
    cursor: pointer;
    transition: transform 0.13s, box-shadow 0.13s;
    position: relative;
  }
  .profile-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }
  .profile-card-actions {
    position: absolute;
    top: 12px; right: 12px;
    display: flex; gap: 4px;
  }

  /* Score bar */
  .score-bar {
    background: linear-gradient(90deg, var(--navy) 0%, var(--navy2) 100%);
    border-radius: 10px;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .score-bar-label { color: rgba(255,255,255,0.65); font-size: 13px; font-weight: 600; }
  .score-bar-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--gold);
  }

  /* Color picker */
  .color-picker { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 4px; }
  .color-swatch {
    width: 26px; height: 26px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    transition: transform 0.12s;
  }
  .color-swatch:hover { transform: scale(1.15); }
  .color-swatch.selected { border-color: #fff; box-shadow: 0 0 0 2px var(--navy); }

  /* Entry log table */
  .entry-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .entry-table th {
    text-align: left;
    padding: 9px 14px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text3);
    border-bottom: 1.5px solid var(--gray1);
    background: var(--offwhite);
  }
  .entry-table td {
    padding: 10px 14px;
    border-bottom: 1px solid var(--gray1);
    color: var(--text2);
  }
  .entry-table tr:last-child td { border-bottom: none; }
  .entry-table tr:hover td { background: var(--offwhite); }
  .entry-score {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--navy);
  }

  /* Top performer banner */
  .top-banner {
    background: linear-gradient(135deg, var(--navy) 0%, #1a3a5c 100%);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }
  .top-banner .trophy { font-size: 28px; }
  .top-banner .info { flex: 1; }
  .top-banner .info .tit { font-size: 11px; color: rgba(255,255,255,0.55); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
  .top-banner .info .name { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 800; color: #fff; }
  .top-banner .info .sub { font-size: 12px; color: rgba(255,255,255,0.6); }
  .top-banner .score-chip {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: var(--gold);
  }

  /* Profile header */
  .profile-header {
    background: #fff;
    border-radius: var(--radius);
    border: 1px solid var(--gray1);
    box-shadow: var(--shadow2);
    padding: 22px 24px;
    margin-bottom: 18px;
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .profile-header .ph-info { flex: 1; min-width: 160px; }
  .profile-header .ph-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 26px;
    font-weight: 800;
    color: var(--navy);
  }
  .profile-header .ph-sub { font-size: 13px; color: var(--text3); margin-top: 2px; }
  .profile-header .ph-badges { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
  .profile-header .ph-actions { display: flex; gap: 8px; flex-wrap: wrap; }

  /* ─── MODALS ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10, 18, 30, 0.72);
    z-index: 500;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }

  .modal {
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
    width: 100%;
    max-width: 440px;
    max-height: 90vh;
    overflow-y: auto;
    padding: 28px 30px;
    position: relative;
    border-top: 4px solid var(--navy);
  }
  .modal-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 20px;
    letter-spacing: 0.3px;
  }
  .modal-close {
    position: absolute;
    top: 18px; right: 18px;
    background: var(--gray1);
    border: none;
    width: 30px; height: 30px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 14px;
    color: var(--text2);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.13s;
  }
  .modal-close:hover { background: var(--gray2); }
  .modal-footer { margin-top: 20px; display: flex; gap: 10px; }
  .modal-footer .btn { flex: 1; justify-content: center; padding: 10px; }

  /* ─── TOAST ─── */
  #toast {
    position: fixed;
    bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--navy);
    color: #fff;
    padding: 12px 22px;
    border-radius: 50px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 6px 24px rgba(0,0,0,0.25);
    z-index: 9999;
    transition: transform 0.3s ease;
    white-space: nowrap;
  }
  #toast.show { transform: translateX(-50%) translateY(0); }

  /* ─── EMPTY STATE ─── */
  .empty {
    text-align: center;
    padding: 48px 20px;
    color: var(--text3);
  }
  .empty i { font-size: 40px; margin-bottom: 12px; display: block; }
  .empty p { font-size: 14px; }

  /* Dashboard two-col */
  .dash-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
  @media (max-width: 600px) { .dash-grid { grid-template-columns: 1fr; } .form-row, .form-row3 { grid-template-columns: 1fr; } }

  .dash-list-row {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 0;
    border-bottom: 1px solid var(--gray1);
    cursor: pointer;
  }
  .dash-list-row:last-child { border-bottom: none; }
  .dash-list-row:hover .drow-name { color: var(--navy); }
  .drow-name { font-size: 13px; font-weight: 600; color: var(--text); flex: 1; }
  .drow-sub { font-size: 11px; color: var(--text3); }
  .drow-score {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--navy);
  }

  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }
  .section-head h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 700; color: var(--navy); }

  /* Back btn */
  .back-btn {
    display: inline-flex; align-items: center; gap: 7px;
    background: none; border: none;
    color: var(--text2); font-size: 13px; font-weight: 600;
    font-family: 'Mulish', sans-serif;
    cursor: pointer; margin-bottom: 18px;
    padding: 6px 0;
  }
  .back-btn:hover { color: var(--navy); }

  /* ─── LOG MODE TOGGLE ─── */
  .log-mode-bar {
    display: flex;
    gap: 0;
    background: #fff;
    border: 1.5px solid var(--gray2);
    border-radius: var(--radius);
    padding: 4px;
    margin-bottom: 16px;
    width: fit-content;
    box-shadow: var(--shadow2);
  }
  .log-mode-btn {
    background: none;
    border: none;
    border-radius: 9px;
    padding: 8px 20px;
    font-family: 'Mulish', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--text3);
    cursor: pointer;
    display: flex; align-items: center; gap: 7px;
    transition: background 0.15s, color 0.15s;
  }
  .log-mode-btn.active {
    background: var(--navy);
    color: #fff;
  }
  .log-mode-btn i { font-size: 14px; }

  /* ─── LOG GAME INFO GRID ─── */
  .log-game-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 14px;
  }
  .log-game-info-grid .form-group { margin-bottom: 0; }

  /* ─── ROSTER CHIPS ─── */
  #log-roster-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 2px;
  }
  .roster-chip {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px 6px 8px;
    border-radius: 50px;
    border: 1.5px solid var(--gray2);
    background: #fff;
    cursor: pointer;
    font-family: 'Mulish', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--text2);
    transition: border-color 0.13s, background 0.13s, color 0.13s;
    user-select: none;
  }
  .roster-chip:hover { border-color: var(--navy); color: var(--navy); }
  .roster-chip.selected {
    border-color: var(--navy);
    background: var(--navy);
    color: #fff;
  }
  .roster-chip .chip-check {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px;
    flex-shrink: 0;
    transition: background 0.13s;
  }
  .roster-chip.selected .chip-check { background: rgba(255,255,255,0.25); border-color: rgba(255,255,255,0.5); }

  /* ─── PLAYER ACCORDION (team session) ─── */
  .player-accordion {
    background: #fff;
    border: 1px solid var(--gray1);
    border-radius: var(--radius);
    box-shadow: var(--shadow2);
    margin-bottom: 10px;
    overflow: hidden;
  }
  .player-accordion-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    cursor: pointer;
    user-select: none;
    border-bottom: 1px solid transparent;
    transition: background 0.13s, border-color 0.13s;
  }
  .player-accordion-header:hover { background: var(--offwhite); }
  .player-accordion.open .player-accordion-header {
    border-bottom-color: var(--gray1);
    background: var(--offwhite);
  }
  .pah-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--navy);
    flex: 1;
  }
  .pah-meta { font-size: 11px; color: var(--text3); }
  .pah-score {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--navy);
    min-width: 44px;
    text-align: right;
  }
  .pah-chevron {
    font-size: 13px;
    color: var(--gray3);
    transition: transform 0.2s;
  }
  .player-accordion.open .pah-chevron { transform: rotate(180deg); }

  .player-accordion-body {
    display: none;
    padding: 16px 18px;
  }
  .player-accordion.open .player-accordion-body { display: block; }

  /* ─── TEAM SESSION SUMMARY BAR ─── */
  .team-session-summary {
    position: sticky;
    bottom: 0;
    background: linear-gradient(90deg, var(--navy) 0%, var(--navy2) 100%);
    border-radius: var(--radius);
    padding: 16px 22px;
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 12px;
    box-shadow: 0 -4px 20px rgba(13,27,42,0.18);
  }

  /* Edit-entry modal compact stats */
  #em-cats .cat-block { margin-bottom: 10px; }
  #em-cats .stat-grid { grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); }
  #em-cats .stat-input-item input { font-size: 14px; padding: 6px 9px; }

  /* Entry table action cell */
  .entry-actions { display: flex; gap: 4px; justify-content: flex-end; }

  /* ─── FORMULAS PAGE ─── */
  .formula-card {
    background: #fff;
    border: 1px solid var(--gray1);
    border-radius: var(--radius);
    box-shadow: var(--shadow2);
    padding: 18px 20px;
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .formula-card-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    font-weight: 800;
    font-family: 'Barlow Condensed', sans-serif;
    flex-shrink: 0;
  }
  .formula-card-body { flex: 1; min-width: 0; }
  .formula-card-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px; font-weight: 700;
    color: var(--navy); margin-bottom: 2px;
  }
  .formula-card-desc { font-size: 12px; color: var(--text3); margin-bottom: 8px; }
  .formula-card-expr {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: var(--offwhite);
    border: 1px solid var(--gray1);
    border-radius: 6px;
    padding: 5px 10px;
    font-size: 13px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    color: var(--text2);
    flex-wrap: wrap;
    max-width: 100%;
  }
  .expr-stat-chip {
    display: inline-flex;
    padding: 2px 7px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    font-family: 'Barlow Condensed', sans-serif;
  }
  .formula-card-actions { display: flex; gap: 4px; flex-shrink: 0; }

  /* Formula result badge on profiles */
  .formula-result-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: 7px 13px;
    border-radius: 8px;
    min-width: 64px;
  }
  .formula-result-badge .frb-val {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 800;
    line-height: 1;
  }
  .formula-result-badge .frb-lbl {
    font-size: 10px;
    font-weight: 600;
    text-align: center;
    margin-top: 2px;
    line-height: 1.2;
  }

  /* ─── FORMULA MODAL EXPRESSION BUILDER ─── */
  .expr-editor {
    border: 1.5px solid var(--gray2);
    border-radius: var(--radius2);
    padding: 12px 14px;
    background: var(--offwhite);
  }
  .expr-display {
    min-height: 42px;
    background: #fff;
    border: 1.5px solid var(--gray2);
    border-radius: 7px;
    padding: 6px 10px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    cursor: text;
    transition: border-color 0.13s;
  }
  .expr-display:focus-within { border-color: var(--navy); }
  .expr-input {
    border: none; outline: none;
    background: transparent;
    font-family: 'Mulish', sans-serif;
    font-size: 14px;
    color: var(--text);
    min-width: 80px;
    flex: 1;
  }
  .expr-token {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 8px;
    border-radius: 5px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 700;
    cursor: default;
    user-select: none;
  }
  .expr-token.stat-token { }
  .expr-token.op-token {
    background: var(--gray1);
    color: var(--navy);
    font-size: 16px;
  }
  .expr-token.num-token {
    background: #e8f0fe;
    color: #1a5cb5;
  }
  .expr-token-del {
    cursor: pointer;
    opacity: 0.5;
    font-size: 10px;
    margin-left: 2px;
  }
  .expr-token-del:hover { opacity: 1; }

  .op-btn {
    padding: 5px 11px;
    border-radius: 6px;
    border: 1.5px solid var(--gray2);
    background: #fff;
    font-size: 15px;
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    cursor: pointer;
    color: var(--navy);
    transition: background 0.12s, border-color 0.12s;
  }
  .op-btn:hover { background: var(--navy); color: #fff; border-color: var(--navy); }
  .op-clear { font-size: 12px; color: var(--text3); margin-left: 4px; }
  .op-clear:hover { background: var(--red); border-color: var(--red); color: #fff; }

  .stat-insert-btn {
    display: inline-flex;
    padding: 4px 10px;
    border-radius: 5px;
    border: 1.5px solid;
    font-size: 12px;
    font-weight: 700;
    font-family: 'Barlow Condensed', sans-serif;
    cursor: pointer;
    transition: opacity 0.12s;
    background: transparent;
  }
  .stat-insert-btn:hover { opacity: 0.75; }

  .fmt-btn {
    padding: 6px 13px;
    border-radius: 6px;
    border: 1.5px solid var(--gray2);
    background: #fff;
    font-family: 'Mulish', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    color: var(--text2);
    transition: all 0.13s;
  }
  .fmt-btn.active {
    background: var(--navy);
    color: #fff;
    border-color: var(--navy);
  }

  .expr-preview {
    margin-top: 8px;
    padding: 8px 12px;
    background: #e8f5e9;
    border-radius: 6px;
    font-size: 13px;
    color: #2e7d32;
    font-weight: 600;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--gray2); border-radius: 3px; }
</style>
</head>
<body>

<!-- HEADER -->
<div id="header">
  <div class="logo">
    <div class="logo-icon"><i class="fa-solid fa-basketball"></i></div>
    <div class="logo-text">COURT<span>IQ</span></div>
  </div>
  <nav id="nav">
    <button class="active" onclick="showPage('dashboard')" data-page="dashboard"><i class="fa-solid fa-gauge-high"></i> Dashboard</button>
    <button onclick="showPage('log')" data-page="log"><i class="fa-solid fa-clipboard-list"></i> Log Stats</button>
    <button onclick="showPage('players')" data-page="players"><i class="fa-solid fa-users"></i> Players</button>
    <button onclick="showPage('teams')" data-page="teams"><i class="fa-solid fa-shirt"></i> Teams</button>
    <button onclick="showPage('categories')" data-page="categories"><i class="fa-solid fa-sliders"></i> Categories</button>
    <button onclick="showPage('formulas')" data-page="formulas"><i class="fa-solid fa-square-root-variable"></i> Formulas</button>
  </nav>
  <div id="save-status">
    <div id="save-indicator" class="saved">
      <div class="dot"></div>
      <span id="save-label">Saved</span>
    </div>
    <button id="btn-save-now" onclick="saveNow()">
      <i class="fa-solid fa-floppy-disk"></i> Save
    </button>
  </div>
</div>

<div id="app">

  <!-- ══════════════════════ DASHBOARD ══════════════════════ -->
  <div id="page-dashboard" class="page active">
    <div class="page-title">Dashboard</div>
    <div class="metrics" id="dash-metrics"></div>
    <div id="dash-top-banner"></div>
    <div class="dash-grid">
      <div class="card">
        <div class="card-body">
          <div class="section-head"><h3>Players</h3><button class="btn btn-sm" onclick="showPage('players')">View all</button></div>
          <div id="dash-players-list"></div>
        </div>
      </div>
      <div class="card">
        <div class="card-body">
          <div class="section-head"><h3>Teams</h3><button class="btn btn-sm" onclick="showPage('teams')">View all</button></div>
          <div id="dash-teams-list"></div>
        </div>
      </div>
    </div>
    <div class="card" style="margin-top:16px;" id="dash-recent-card">
      <div class="card-body">
        <div class="section-head"><h3>Recent Entries</h3></div>
        <div id="dash-recent"></div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ LOG STATS ══════════════════════ -->
  <div id="page-log" class="page">
    <div class="page-title">Log Statistics</div>

    <!-- Mode toggle -->
    <div class="log-mode-bar">
      <button class="log-mode-btn active" id="mode-btn-single" onclick="setLogMode('single')">
        <i class="fa-solid fa-user"></i> Single Player
      </button>
      <button class="log-mode-btn" id="mode-btn-team" onclick="setLogMode('team')">
        <i class="fa-solid fa-users"></i> Team Session
      </button>
    </div>

    <!-- Shared game info -->
    <div class="card" style="margin-bottom:16px;">
      <div class="card-body">
        <div class="log-game-info-grid">
          <!-- single-player-only field -->
          <div class="form-group log-single-only">
            <label>Player</label>
            <select class="form-control" id="log-player"></select>
          </div>
          <!-- team session field -->
          <div class="form-group log-team-only" style="display:none;">
            <label>Team</label>
            <select class="form-control" id="log-team-session" onchange="renderTeamRoster()"></select>
          </div>
          <!-- single mode team -->
          <div class="form-group log-single-only">
            <label>Team</label>
            <select class="form-control" id="log-team"></select>
          </div>
          <div class="form-group">
            <label>Date</label>
            <input type="date" class="form-control" id="log-date">
          </div>
          <div class="form-group">
            <label>Opponent</label>
            <input type="text" class="form-control" id="log-opponent" placeholder="Opponent name…">
          </div>
        </div>

        <!-- Team session: player selector chips -->
        <div id="log-roster-select" class="log-team-only" style="display:none;">
          <div style="font-size:11px;font-weight:700;color:var(--text2);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">
            Select players to include in this session
          </div>
          <div id="log-roster-chips"></div>
        </div>
      </div>
    </div>

    <!-- Single player stat entry -->
    <div id="log-single-body">
      <div id="log-cats"></div>
      <div class="score-bar">
        <span class="score-bar-label">Aggregate Score</span>
        <span class="score-bar-value" id="log-score-display">0</span>
      </div>
      <button class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;" onclick="submitEntry()">
        <i class="fa-solid fa-circle-check"></i> Log Entry
      </button>
    </div>

    <!-- Team session stat entry (accordion per player) -->
    <div id="log-team-body" style="display:none;">
      <div id="log-team-players"></div>
      <!-- Team session summary bar -->
      <div class="team-session-summary" id="log-team-summary" style="display:none;">
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,0.55);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Players</div>
          <div id="tss-count" style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:#fff;">0</div>
        </div>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,0.55);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Total Score</div>
          <div id="tss-total" style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:var(--gold);">0</div>
        </div>
        <div>
          <div style="font-size:11px;color:rgba(255,255,255,0.55);font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Avg Score</div>
          <div id="tss-avg" style="font-family:'Barlow Condensed',sans-serif;font-size:22px;font-weight:800;color:var(--gold);">0</div>
        </div>
        <button class="btn" style="background:var(--gold);color:#fff;border-color:var(--gold);font-size:13px;padding:10px 22px;flex-shrink:0;" onclick="submitTeamSession()">
          <i class="fa-solid fa-circle-check"></i> Log All Entries
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ PLAYERS ══════════════════════ -->
  <div id="page-players" class="page">
    <div class="section-head">
      <div class="page-title" style="margin:0">Players</div>
      <button class="btn btn-primary" onclick="openPlayerModal(null)"><i class="fa-solid fa-plus"></i> Add Player</button>
    </div>
    <div class="profile-grid" id="players-grid"></div>
  </div>

  <!-- ══════════════════════ PLAYER PROFILE ══════════════════════ -->
  <div id="page-player-profile" class="page">
    <button class="back-btn" onclick="showPage('players')"><i class="fa-solid fa-arrow-left"></i> Back to Players</button>
    <div id="player-profile-content"></div>
  </div>

  <!-- ══════════════════════ TEAMS ══════════════════════ -->
  <div id="page-teams" class="page">
    <div class="section-head">
      <div class="page-title" style="margin:0">Teams</div>
      <button class="btn btn-primary" onclick="openTeamModal(null)"><i class="fa-solid fa-plus"></i> Add Team</button>
    </div>
    <div class="profile-grid" id="teams-grid"></div>
  </div>

  <!-- ══════════════════════ TEAM PROFILE ══════════════════════ -->
  <div id="page-team-profile" class="page">
    <button class="back-btn" onclick="showPage('teams')"><i class="fa-solid fa-arrow-left"></i> Back to Teams</button>
    <div id="team-profile-content"></div>
  </div>

  <!-- ══════════════════════ CATEGORIES ══════════════════════ -->
  <div id="page-categories" class="page">
    <div class="section-head">
      <div class="page-title" style="margin:0">Categories</div>
      <button class="btn btn-primary" onclick="openCatModal(null)"><i class="fa-solid fa-plus"></i> Add Category</button>
    </div>
    <div id="categories-list"></div>
  </div>
  <!-- ══════════════════════ FORMULAS ══════════════════════ -->
  <div id="page-formulas" class="page">
    <div class="section-head">
      <div class="page-title" style="margin:0">Formulas</div>
      <button class="btn btn-primary" onclick="openFormulaModal(null)"><i class="fa-solid fa-plus"></i> Add Formula</button>
    </div>
    <p style="font-size:13px;color:var(--text3);margin-bottom:18px;line-height:1.6;">
      Formulas combine raw statistics into calculated metrics like shooting percentages, rates, and efficiencies.
      They are displayed on player and team profiles and included in exports.
    </p>
    <div id="formulas-list"></div>
  </div>

</div><!-- /app -->

<!-- ══════════════════════ MODALS ══════════════════════ -->

<!-- Player Modal -->
<div class="modal-overlay" id="modal-player">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('modal-player')"><i class="fa-solid fa-xmark"></i></button>
    <div class="modal-title" id="player-modal-title">Add Player</div>
    <div class="form-group"><label>Full Name</label><input class="form-control" id="pm-name" placeholder="e.g. Marcus Johnson"></div>
    <div class="form-row">
      <div class="form-group"><label>Number</label><input class="form-control" id="pm-number" placeholder="#23"></div>
      <div class="form-group"><label>Position</label><input class="form-control" id="pm-position" placeholder="SG"></div>
    </div>
    <div class="form-group">
      <label>Team</label>
      <select class="form-control" id="pm-team"><option value="">No team</option></select>
    </div>
    <div class="form-group">
      <label>Avatar Color</label>
      <div class="color-picker" id="pm-colors"></div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-player')">Cancel</button>
      <button class="btn btn-primary" onclick="savePlayer()">Save Player</button>
    </div>
  </div>
</div>

<!-- Team Modal -->
<div class="modal-overlay" id="modal-team">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('modal-team')"><i class="fa-solid fa-xmark"></i></button>
    <div class="modal-title" id="team-modal-title">Add Team</div>
    <div class="form-group"><label>Team Name</label><input class="form-control" id="tm-name" placeholder="e.g. Downtown Ballers"></div>
    <div class="form-group">
      <label>Team Color</label>
      <div class="color-picker" id="tm-colors"></div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-team')">Cancel</button>
      <button class="btn btn-primary" onclick="saveTeam()">Save Team</button>
    </div>
  </div>
</div>

<!-- Category Modal -->
<div class="modal-overlay" id="modal-cat">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('modal-cat')"><i class="fa-solid fa-xmark"></i></button>
    <div class="modal-title" id="cat-modal-title">Add Category</div>
    <div class="form-group"><label>Category Name</label><input class="form-control" id="cm-name" placeholder="e.g. Defense"></div>
    <div class="form-group">
      <label>Category Color</label>
      <div class="color-picker" id="cm-colors"></div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-cat')">Cancel</button>
      <button class="btn btn-primary" onclick="saveCat()">Save Category</button>
    </div>
  </div>
</div>

<!-- Stat Modal -->
<div class="modal-overlay" id="modal-stat">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('modal-stat')"><i class="fa-solid fa-xmark"></i></button>
    <div class="modal-title" id="stat-modal-title">Add Stat</div>
    <div id="stat-modal-cat-label" style="font-size:12px;color:var(--text3);margin-bottom:14px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;"></div>
    <div class="form-group"><label>Stat Name</label><input class="form-control" id="sm-name" placeholder="e.g. Steals"></div>
    <div class="form-group">
      <label>Point Value Multiplier</label>
      <input class="form-control" id="sm-value" type="number" step="0.25" placeholder="e.g. 2">
      <p style="font-size:11px;color:var(--text3);margin-top:5px;">Each unit of this stat counts for this many points toward the aggregate score.</p>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeModal('modal-stat')">Cancel</button>
      <button class="btn btn-primary" onclick="saveStat()">Save Stat</button>
    </div>
  </div>
</div>

<!-- Edit Entry Modal -->
<div class="modal-overlay" id="modal-entry">
  <div class="modal" style="max-width:580px;">
    <button class="modal-close" onclick="closeModal('modal-entry')"><i class="fa-solid fa-xmark"></i></button>
    <div class="modal-title">Edit Entry</div>

    <div class="form-row" style="margin-bottom:14px;">
      <div class="form-group" style="margin-bottom:0;">
        <label>Player</label>
        <select class="form-control" id="em-player"></select>
      </div>
      <div class="form-group" style="margin-bottom:0;">
        <label>Team</label>
        <select class="form-control" id="em-team"></select>
      </div>
      <div class="form-group" style="margin-bottom:0;">
        <label>Date</label>
        <input type="date" class="form-control" id="em-date">
      </div>
      <div class="form-group" style="margin-bottom:0;">
        <label>Opponent</label>
        <input type="text" class="form-control" id="em-opponent" placeholder="Opponent name…">
      </div>
    </div>

    <div id="em-cats"></div>

    <div style="background:linear-gradient(90deg,var(--navy),var(--navy2));border-radius:10px;padding:12px 18px;display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <span style="color:rgba(255,255,255,0.65);font-size:13px;font-weight:600;">Aggregate Score</span>
      <span id="em-score-display" style="font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:800;color:var(--gold);">0</span>
    </div>

    <div class="modal-footer" style="justify-content:space-between;">
      <button class="btn btn-red btn-sm" onclick="deleteEntry()" style="gap:6px;"><i class="fa-solid fa-trash"></i> Delete Entry</button>
      <div style="display:flex;gap:10px;">
        <button class="btn" onclick="closeModal('modal-entry')">Cancel</button>
        <button class="btn btn-primary" onclick="saveEditEntry()"><i class="fa-solid fa-circle-check"></i> Save Changes</button>
      </div>
    </div>
  </div>
</div>

<!-- Formula Modal -->
