      {type:'op',label:')',value:')'},
    ]
  },
  {
    id:'ftr', name:'Free Throw Rate', desc:'FT Attempted ÷ (2PT Att + 3PT Att)',
    format:'decimal2', color:'#e65100',
    tokens:[
      {type:'stat',id:'fta',label:'FT Att'},
      {type:'op',label:'÷',value:'/'},
      {type:'op',label:'(',value:'('},
      {type:'stat',id:'fg2a',label:'2PT Att'},
      {type:'op',label:'+',value:'+'},
      {type:'stat',id:'fg3a',label:'3PT Att'},
      {type:'op',label:')',value:')'},
    ]
  },
  {
    id:'ftpct', name:'Free Throw %', desc:'FT Made ÷ FT Attempted',
    format:'percent', color:'#6a1b9a',
    tokens:[
      {type:'stat',id:'ftm',label:'FT Made'},
      {type:'op',label:'÷',value:'/'},
      {type:'stat',id:'fta',label:'FT Att'},
    ]
  },
  {
    id:'threepct', name:'3PT %', desc:'3PT Made ÷ 3PT Attempted',
    format:'percent', color:'#00838f',
    tokens:[
      {type:'stat',id:'fg3m',label:'3PT Made'},
      {type:'op',label:'÷',value:'/'},
      {type:'stat',id:'fg3a',label:'3PT Att'},
    ]
  },
];

// ═══════════════════════════════════════════════════════
//  LOCALSTORAGE PERSISTENCE
// ═══════════════════════════════════════════════════════
const LS_KEY = 'courtiq_v1';

function loadData() {
  try {
    const raw = localStorage.getItem(LS_KEY);
    if (!raw) return null;
    return JSON.parse(raw);
  } catch(e) { return null; }
}

function persistData() {
  try {
    localStorage.setItem(LS_KEY, JSON.stringify({ categories, players, teams, entries, formulas, savedAt: Date.now() }));
    return true;
  } catch(e) { return false; }
}

// ── Autosave machinery ──
let _autosaveTimer = null;
let _isDirty = false;

function markDirty() {
  _isDirty = true;
  setSaveStatus('unsaved', 'Unsaved changes');
  clearTimeout(_autosaveTimer);
  _autosaveTimer = setTimeout(() => { saveNow(true); }, 2500);
}

function saveNow(isAuto = false) {
  clearTimeout(_autosaveTimer);
  setSaveStatus('saving', 'Saving…');
  setTimeout(() => {                     // tiny delay so "Saving…" is visible
    const ok = persistData();
    _isDirty = false;
    if (ok) {
      const now = new Date().toLocaleTimeString('en-US', {hour:'numeric', minute:'2-digit'});
      setSaveStatus('saved', isAuto ? `Auto-saved ${now}` : `Saved ${now}`);
    } else {
      setSaveStatus('unsaved', 'Save failed');
    }
  }, 180);
}

function setSaveStatus(state, label) {
  const ind = document.getElementById('save-indicator');
  ind.className = state;
  document.getElementById('save-label').textContent = label;
}

// ── Wrap every mutating operation to trigger markDirty ──
function mutate(fn) {
  fn();
  markDirty();
}

// ── Load saved data or use defaults ──
const saved = loadData();
let categories = saved?.categories ?? JSON.parse(JSON.stringify(DEFAULT_CATEGORIES));
let players    = saved?.players    ?? JSON.parse(JSON.stringify(DEFAULT_PLAYERS));
let teams      = saved?.teams      ?? JSON.parse(JSON.stringify(DEFAULT_TEAMS));
let entries    = saved?.entries    ?? [];
let formulas   = saved?.formulas   ?? JSON.parse(JSON.stringify(DEFAULT_FORMULAS));

// Modal state
let editingPlayer = null;
let editingTeam = null;
let editingCat = null;
let editingStat = null; // {catId, stat|null}
let editingEntryId = null;
let editingFormula = null;
let selectedPlayerColor = COLORS[0];
let selectedTeamColor = COLORS[0];
let selectedCatColor = COLORS[0];
let selectedFormulaColor = COLORS[0];

// ═══════════════════════════════════════════════════════
//  UTILS
// ═══════════════════════════════════════════════════════
const genId = () => '_' + Math.random().toString(36).slice(2,9);
const fmt = d => new Date(d + 'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});

function computeScore(statValues) {
  let s = 0;
  categories.forEach(c => c.stats.forEach(st => { s += parseFloat(statValues[st.id]||0) * st.value; }));
  return Math.round(s * 10) / 10;
}
function playerEntries(pid) { return entries.filter(e => e.playerId === pid); }
function teamEntries(tid) { return entries.filter(e => e.teamId === tid); }
function avgScore(list) {
  if (!list.length) return 0;
  return Math.round(list.reduce((s,e) => s + computeScore(e.statValues), 0) / list.length * 10) / 10;
}
function totalStat(list, sid) { return list.reduce((s,e) => s + parseFloat(e.statValues[sid]||0), 0); }

function initials(name) { return name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }

function avatar(name, color, size=38) {
  return `<div class="avatar" style="width:${size}px;height:${size}px;background:${color};font-size:${Math.round(size*0.35)}px;">${initials(name)}</div>`;
}

function statBadge(label, val, color) {
  return `<div class="stat-badge" style="background:${color}18;">
    <span class="val" style="color:${color};">${val}</span>
    <span class="lbl" style="color:${color}cc;">${label}</span>
  </div>`;
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// ═══════════════════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════════════════
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('nav button').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  const nb = document.querySelector(`nav button[data-page="${id}"]`);
  if (nb) nb.classList.add('active');
  // Re-render
  if (id === 'dashboard') renderDashboard();
  if (id === 'log') renderLog();
  if (id === 'players') renderPlayers();
  if (id === 'teams') renderTeams();
  if (id === 'categories') renderCategories();
  if (id === 'formulas') renderFormulas();
  window.scrollTo(0,0);
}

// ═══════════════════════════════════════════════════════
//  DASHBOARD
// ═══════════════════════════════════════════════════════
function renderDashboard() {
  const allScores = entries.map(e => computeScore(e.statValues));
  const avgAll = entries.length ? Math.round(allScores.reduce((a,b)=>a+b,0)/entries.length*10)/10 : 0;
  const uniqueP = [...new Set(entries.map(e=>e.playerId))].length;

  document.getElementById('dash-metrics').innerHTML = [
    {label:'Entries',val:entries.length,icon:'fa-clipboard-list',color:'#1565c0'},
    {label:'Players Active',val:uniqueP,icon:'fa-users',color:'#2e7d32'},
    {label:'Avg Score',val:avgAll,icon:'fa-star',color:'#e65100'},
    {label:'Teams',val:teams.length,icon:'fa-shirt',color:'#c62828'},
  ].map(m => `<div class="metric-card" style="border-top-color:${m.color};">
    <div class="mc-label"><i class="fa-solid ${m.icon}" style="color:${m.color}"></i>${m.label}</div>
    <div class="mc-value">${m.val}</div>
  </div>`).join('');

  // Top performer
  let topHtml = '';
  if (entries.length) {
    const byP = {};
    entries.forEach(e => { if (!byP[e.playerId]) byP[e.playerId]=[]; byP[e.playerId].push(computeScore(e.statValues)); });
    let bestId=null, bestAvg=-Infinity;
    Object.entries(byP).forEach(([pid,sc])=>{ const a=sc.reduce((x,y)=>x+y,0)/sc.length; if(a>bestAvg){bestAvg=a;bestId=pid;} });
    const bp = players.find(p=>p.id===bestId);
    if (bp) {
      topHtml = `<div class="top-banner">
        <div class="trophy">🏆</div>
        <div class="info">
          <div class="tit">Top Performer (avg score)</div>
          <div class="name">${bp.name}</div>
          <div class="sub">${playerEntries(bp.id).length} entries recorded</div>
        </div>
        <div class="score-chip">${Math.round(bestAvg*10)/10}</div>
      </div>`;
    }
  }
  document.getElementById('dash-top-banner').innerHTML = topHtml;

  // Players list
  const pl = players.slice(0,6).map(p => {
    const pe = playerEntries(p.id);
    return `<div class="dash-list-row" onclick="openPlayerProfile('${p.id}')">
      ${avatar(p.name, p.color, 30)}
      <div style="flex:1;">
        <div class="drow-name">${p.name}</div>
        <div class="drow-sub">${pe.length} entries · avg ${avgScore(pe)}</div>
      </div>
      <div class="drow-score">${avgScore(pe)}</div>
    </div>`;
  }).join('');
  document.getElementById('dash-players-list').innerHTML = pl || '<div class="empty" style="padding:24px 0"><i class="fa-solid fa-users"></i><p>No players yet</p></div>';

  // Teams list
  const tl = teams.map(t => {
    const te = teamEntries(t.id);
    return `<div class="dash-list-row" onclick="openTeamProfile('${t.id}')">
      <div style="width:30px;height:30px;background:${t.color}22;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <i class="fa-solid fa-shirt" style="color:${t.color};font-size:14px;"></i>
      </div>
      <div style="flex:1;">
        <div class="drow-name">${t.name}</div>
        <div class="drow-sub">${te.length} entries · avg ${avgScore(te)}</div>
      </div>
      <div class="drow-score">${avgScore(te)}</div>
    </div>`;
  }).join('');
  document.getElementById('dash-teams-list').innerHTML = tl || '<div class="empty" style="padding:24px 0"><i class="fa-solid fa-shirt"></i><p>No teams yet</p></div>';

  // Recent entries
  if (entries.length) {
    const recent = entries.slice().reverse().slice(0,8);
    document.getElementById('dash-recent').innerHTML = `<table class="entry-table">
      <thead><tr><th>Date</th><th>Player</th><th>Team</th><th>Opponent</th><th style="text-align:right">Score</th><th></th></tr></thead>
      <tbody>${recent.map(e => {
        const p = players.find(x=>x.id===e.playerId);
        const t = teams.find(x=>x.id===e.teamId);
        return `<tr>
          <td>${fmt(e.date)}</td>
          <td><div style="display:flex;align-items:center;gap:8px;">${p?avatar(p.name,p.color,24):''}${p?.name||'—'}</div></td>
          <td>${t?.name||'—'}</td>
          <td>${e.opponent||'—'}</td>
          <td style="text-align:right"><span class="entry-score">${computeScore(e.statValues)}</span></td>
          <td><div class="entry-actions">
            <button class="btn-icon" title="Edit entry" onclick="openEditEntryModal('${e.id}')"><i class="fa-solid fa-pen"></i></button>
          </div></td>
        </tr>`;
      }).join('')}</tbody>
    </table>`;
    document.getElementById('dash-recent-card').style.display = '';
  } else {
    document.getElementById('dash-recent-card').style.display = 'none';
  }
}

// ═══════════════════════════════════════════════════════
//  LOG STATS – TWO-MODE SYSTEM
// ═══════════════════════════════════════════════════════
let logMode = 'single';                // 'single' | 'team'
let teamSessionSelected = new Set();   // player IDs selected for team session

function setLogMode(mode) {
  logMode = mode;
  document.getElementById('mode-btn-single').classList.toggle('active', mode === 'single');
  document.getElementById('mode-btn-team').classList.toggle('active', mode === 'team');

  // Show/hide mode-specific elements
  document.querySelectorAll('.log-single-only').forEach(el => el.style.display = mode === 'single' ? '' : 'none');
  document.querySelectorAll('.log-team-only').forEach(el => el.style.display = mode === 'team' ? '' : 'none');
  document.getElementById('log-single-body').style.display = mode === 'single' ? '' : 'none';
  document.getElementById('log-team-body').style.display = mode === 'team' ? '' : 'none';

  if (mode === 'team') {
    renderTeamRoster();
  }
}

function renderLog() {
  // Single-player selects
  const lp = document.getElementById('log-player');
  lp.innerHTML = '<option value="">Select player…</option>' + players.map(p => `<option value="${p.id}">${p.name}</option>`).join('');
  const lt = document.getElementById('log-team');
  lt.innerHTML = '<option value="">Select team…</option>' + teams.map(t => `<option value="${t.id}">${t.name}</option>`).join('');

  // Team-session team selector
  const lts = document.getElementById('log-team-session');
  lts.innerHTML = '<option value="">Select team…</option>' + teams.map(t => `<option value="${t.id}">${t.name}</option>`).join('');

  // Default date
  if (!document.getElementById('log-date').value)
    document.getElementById('log-date').value = new Date().toISOString().slice(0, 10);

  // Build single-player stat inputs
  buildStatInputs('log-cats', 'log-stat-', updateLogScore);
  updateLogScore();

  // Reset team session
  teamSessionSelected = new Set();
  document.getElementById('log-team-players').innerHTML = '';
  document.getElementById('log-team-summary').style.display = 'none';
  document.getElementById('log-roster-chips').innerHTML = '';

  // Apply current mode visibility
  setLogMode(logMode);
}

function buildStatInputs(containerId, idPrefix, onInput, values = {}) {
  document.getElementById(containerId).innerHTML = categories.map(cat => `
    <div class="cat-block" style="border-left-color:${cat.color};">
      <div class="cat-block-header">
        <div class="cat-block-title" style="color:${cat.color};">${cat.name}</div>
      </div>
      <div class="cat-block-stats">
        <div class="stat-grid">
          ${cat.stats.map(s => `
            <div class="stat-input-item">
              <label>${s.name} <span>×${s.value} pts</span></label>
              <input type="number" min="0" id="${idPrefix}${s.id}"
                value="${values[s.id] ?? 0}"
                oninput="${onInput.name}()">
            </div>`).join('')}
        </div>
      </div>
    </div>`).join('');
}

function readStatInputs(idPrefix) {
  const sv = {};
  categories.forEach(c => c.stats.forEach(s => {
    const el = document.getElementById(idPrefix + s.id);
    if (el) sv[s.id] = parseFloat(el.value) || 0;
  }));
  return sv;
}

function updateLogScore() {
  const sv = readStatInputs('log-stat-');
  document.getElementById('log-score-display').textContent = computeScore(sv);
}

// ── SINGLE PLAYER submit ──
function submitEntry() {
  const playerId = document.getElementById('log-player').value;
  const teamId   = document.getElementById('log-team').value;
  const date     = document.getElementById('log-date').value;
  const opponent = document.getElementById('log-opponent').value.trim();
  if (!playerId) return showToast('Please select a player');
  if (!teamId)   return showToast('Please select a team');
  const sv = readStatInputs('log-stat-');
  entries.push({ id: genId(), playerId, teamId, date, opponent, statValues: sv });
  markDirty();
  showToast('Entry logged successfully!');
  renderLog();
}

// ── TEAM SESSION ──
function renderTeamRoster() {
  const tid = document.getElementById('log-team-session').value;
  const roster = players.filter(p => p.teamId === tid);
  teamSessionSelected = new Set(roster.map(p => p.id)); // default: all selected

  const chips = document.getElementById('log-roster-chips');
  if (!tid) {
    chips.innerHTML = '';
    document.getElementById('log-roster-select').style.display = 'none';
    document.getElementById('log-team-players').innerHTML = '';
    document.getElementById('log-team-summary').style.display = 'none';
    return;
  }
  document.getElementById('log-roster-select').style.display = '';

  chips.innerHTML = roster.length
    ? roster.map(p => `
        <div class="roster-chip selected" id="chip-${p.id}" onclick="togglePlayerChip('${p.id}')">
          <div class="chip-check"><i class="fa-solid fa-check"></i></div>
          ${initials(p.name)}
          <span>${p.name.split(' ')[0]}</span>
          <span style="opacity:0.6;font-size:10px;">#${p.number}</span>
        </div>`).join('')
    : `<span style="font-size:13px;color:var(--text3);">No players assigned to this team.</span>`;

  buildTeamPlayerAccordions();
}

function togglePlayerChip(pid) {
  if (teamSessionSelected.has(pid)) {
    teamSessionSelected.delete(pid);
  } else {
    teamSessionSelected.add(pid);
  }
  document.getElementById('chip-' + pid)?.classList.toggle('selected', teamSessionSelected.has(pid));
  buildTeamPlayerAccordions();
}

function buildTeamPlayerAccordions() {
  const tid = document.getElementById('log-team-session').value;
  const roster = players.filter(p => p.teamId === tid && teamSessionSelected.has(p.id));

  const container = document.getElementById('log-team-players');
  if (!roster.length) {
    container.innerHTML = `<div class="empty"><i class="fa-solid fa-user-slash"></i><p>No players selected. Choose players above.</p></div>`;
    document.getElementById('log-team-summary').style.display = 'none';
    return;
  }

  // Preserve existing input values so re-renders don't wipe them
  const existing = {};
  roster.forEach(p => {
    const pv = {};
    categories.forEach(c => c.stats.forEach(s => {
      const el = document.getElementById(`ts-${p.id}-${s.id}`);
      if (el) pv[s.id] = el.value;
    }));
    if (Object.keys(pv).length) existing[p.id] = pv;
  });

  container.innerHTML = roster.map(p => {
    const vals = existing[p.id] || {};
    return `
      <div class="player-accordion open" id="acc-${p.id}">
        <div class="player-accordion-header" onclick="toggleAccordion('${p.id}')">
          ${avatar(p.name, p.color, 34)}
          <div style="flex:1;">
            <div class="pah-name">${p.name}</div>
            <div class="pah-meta">#${p.number} · ${p.position}</div>
          </div>
          <div class="pah-score" id="acc-score-${p.id}">0</div>
          <i class="fa-solid fa-chevron-down pah-chevron"></i>
        </div>
        <div class="player-accordion-body">
          ${categories.map(cat => `
            <div class="cat-block" style="border-left-color:${cat.color};margin-bottom:10px;">
              <div class="cat-block-header">
                <div class="cat-block-title" style="color:${cat.color};">${cat.name}</div>
              </div>
              <div class="cat-block-stats">
                <div class="stat-grid">
                  ${cat.stats.map(s => `
                    <div class="stat-input-item">
                      <label>${s.name} <span>×${s.value} pts</span></label>
                      <input type="number" min="0"
                        id="ts-${p.id}-${s.id}"
                        value="${vals[s.id] ?? 0}"
                        oninput="updateTeamSessionScore('${p.id}')">
                    </div>`).join('')}
                </div>
              </div>
            </div>`).join('')}
        </div>
      </div>`;
  }).join('');

  document.getElementById('log-team-summary').style.display = '';
  roster.forEach(p => updateTeamSessionScore(p.id));
  updateTeamSessionTotals();
}

function toggleAccordion(pid) {
  document.getElementById('acc-' + pid)?.classList.toggle('open');
}

function updateTeamSessionScore(pid) {
  const sv = {};
  categories.forEach(c => c.stats.forEach(s => {
    const el = document.getElementById(`ts-${pid}-${s.id}`);
    if (el) sv[s.id] = el.value;
  }));
  const scoreEl = document.getElementById('acc-score-' + pid);
  if (scoreEl) scoreEl.textContent = computeScore(sv);
  updateTeamSessionTotals();
}

function updateTeamSessionTotals() {
  const tid = document.getElementById('log-team-session').value;
  const roster = players.filter(p => p.teamId === tid && teamSessionSelected.has(p.id));
  let total = 0;
  roster.forEach(p => {
    const el = document.getElementById('acc-score-' + p.id);
    total += parseFloat(el?.textContent || 0);
  });
  const avg = roster.length ? Math.round(total / roster.length * 10) / 10 : 0;
  document.getElementById('tss-count').textContent = roster.length;
  document.getElementById('tss-total').textContent = Math.round(total * 10) / 10;
  document.getElementById('tss-avg').textContent = avg;
}

function submitTeamSession() {
  const tid      = document.getElementById('log-team-session').value;
  const date     = document.getElementById('log-date').value;
  const opponent = document.getElementById('log-opponent').value.trim();
  if (!tid) return showToast('Please select a team');

  const roster = players.filter(p => p.teamId === tid && teamSessionSelected.has(p.id));
  if (!roster.length) return showToast('No players selected');

  let count = 0;
  roster.forEach(p => {
    const sv = {};
    categories.forEach(c => c.stats.forEach(s => {
      const el = document.getElementById(`ts-${p.id}-${s.id}`);
      sv[s.id] = parseFloat(el?.value || 0);
    }));
    entries.push({ id: genId(), playerId: p.id, teamId: tid, date, opponent, statValues: sv });
    count++;
  });

  markDirty();
  showToast(`${count} entr${count === 1 ? 'y' : 'ies'} logged!`);
  renderLog();
}

