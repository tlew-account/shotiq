            <button class="op-btn" onclick="insertOperator('−')">−</button>
            <button class="op-btn" onclick="insertOperator('×')">×</button>
            <button class="op-btn" onclick="insertOperator('÷')">÷</button>
            <button class="op-btn" onclick="insertOperator('(')">(</button>
